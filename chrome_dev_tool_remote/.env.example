# Chrome DevTools Remote Debugging
CHROME_DEBUG_HOST=localhost          # Chrome remote debugging host
CHROME_DEBUG_PORT=9222              # Chrome remote debugging port
CHROME_DB_PATH=./data/chrome_logs.duckdb  # DuckDB database path

# SSH Port Forwarding (optional)
SSH_ENABLED=false                    # true to enable SSH tunnel
SSH_HOST=                            # SSH server hostname/IP
SSH_PORT=22                          # SSH server port
SSH_USER=                            # SSH username (optional, uses default)
SSH_KEY=                             # SSH private key path (optional)
SSH_LOCAL_PORT=9222                   # Local port for tunnel
SSH_REMOTE_PORT=9222                 # Remote Chrome debugging port
